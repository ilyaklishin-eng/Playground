# NКРЯ API integration for first-usage lookup (/api/nkry/search)

NKRY_API_BASE_URL=https://ruscorpora.ru/api/v1/
NKRY_SEARCH_PATH=lex-gramm/concordance
NKRY_API_KEY=<your-api-key>
NKRY_API_KEY_HEADER=Authorization
NKRY_API_AUTH_PREFIX=Bearer
NKRY_CORPUS_TYPE=MAIN

# Optional lookup tuning
NKRY_FIRST_USAGE_MAX_PAGES=8
NKRY_FETCH_TIMEOUT_MS=9000
NKRY_FETCH_RETRIES=2

# Local server
PORT=4173
HOST=127.0.0.1
