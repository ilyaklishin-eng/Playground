# NКРЯ API integration for first-usage lookup (/api/nkry/search)

NKRY_API_BASE_URL=https://ruscorpora.ru/api/v1/
NKRY_SEARCH_PATH=lex-gramm/concordance
NKRY_API_KEY=<your-api-key>
NKRY_API_KEY_HEADER=Authorization
NKRY_API_AUTH_PREFIX=Bearer
NKRY_CORPUS_TYPE=MAIN
NKRY_SORTING=grcreated

# Optional lookup tuning
NKRY_FIRST_USAGE_MAX_PAGES=12
NKRY_DEEP_SCAN_MAX_PAGES=42
NKRY_DEEP_SCAN_YEAR_THRESHOLD=1900
NKRY_HIGH_FREQ_PAGE_THRESHOLD=1200
NKRY_HIGH_FREQ_DEEP_SCAN_MAX_PAGES=28
NKRY_HIGH_FREQ_SPREAD_SCAN_POINTS=10
NKRY_HIGH_FREQ_TAIL_SCAN_PAGES=12
NKRY_FETCH_TIMEOUT_MS=12000
NKRY_FETCH_RETRIES=1
NKRY_FETCH_BACKOFF_MS=280
NKRY_FETCH_BACKOFF_JITTER_MS=220
NKRY_RATE_LIMIT_COOLDOWN_MIN_SEC=6
NKRY_RATE_LIMIT_COOLDOWN_MAX_SEC=120
NKRY_MAX_TOTAL_PAGES=96
NKRY_MAX_TOTAL_MS=12000
NKRY_STRICT_MAX_TOTAL_PAGES=220
NKRY_STRICT_MAX_TOTAL_MS=28000
NKRY_EMPTY_SCAN_STOP_PAGES=6
NKRY_EARLY_EXIT_YEAR=1850
NKRY_CACHE_TTL_MS=300000
NKRY_CACHE_STALE_TTL_MS=3600000
NKRY_CACHE_MAX_ENTRIES=300
NKRY_PAGE_CACHE_TTL_MS=90000
NKRY_PAGE_CACHE_STALE_TTL_MS=1800000
NKRY_PAGE_CACHE_MAX_ENTRIES=2000
NKRY_WARM_CACHE_ENABLED=1
NKRY_WARM_CACHE_INTERVAL_MS=45000
NKRY_WARM_CACHE_TOP_WORDS=8
NKRY_WARM_CACHE_MIN_HITS=2

# Local server
PORT=4173
HOST=127.0.0.1
